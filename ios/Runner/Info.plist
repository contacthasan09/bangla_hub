<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" 
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- ========================= -->
    <!-- 📱 APP BASIC INFO -->
    <!-- ========================= -->
    
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>

    <key>CFBundleDisplayName</key>
    <string>Bangla Hub</string>

    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>

    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <key>CFBundleName</key>
    <string>bangla_hub</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleShortVersionString</key>
    <string>$(FLUTTER_BUILD_NAME)</string>

    <key>CFBundleVersion</key>
    <string>$(FLUTTER_BUILD_NUMBER)</string>

    <key>LSRequiresIPhoneOS</key>
    <true/>

    <!-- ========================= -->
    <!-- 🚀 LAUNCH SCREEN -->
    <!-- ========================= -->

    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <key>UIMainStoryboardFile</key>
    <string>Main</string>

    <!-- ========================= -->
    <!-- 🔄 ORIENTATION -->
    <!-- ========================= -->

    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <key>CADisableMinimumFrameDurationOnPhone</key>
    <true/>

    <key>UIApplicationSupportsIndirectInputEvents</key>
    <true/>

    <!-- ========================= -->
    <!-- 🔐 PERMISSIONS (ONLY NEEDED) -->
    <!-- ========================= -->

    <!-- Location - When In Use (Required for nearby services) -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>Bangla Hub uses your location to show nearby events, services, and businesses in your area.</string>

    <!-- Camera - For profile pictures and event photos -->
    <key>NSCameraUsageDescription</key>
    <string>Bangla Hub needs camera access to take photos for your profile, events, and service listings.</string>

    <!-- Photo Library - For uploading images -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Bangla Hub needs access to your photo library to upload profile pictures and event images.</string>

    <!-- Photo Library Add - For saving images -->
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>Bangla Hub needs permission to save images to your gallery.</string>

    <!-- ========================= -->
    <!-- 🌐 DEEP LINKING (Custom Scheme Only) -->
    <!-- ========================= -->

    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>Bangla Hub Custom Scheme</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>banglahub</string>
            </array>
        </dict>
    </array>

    <!-- ========================= -->
    <!-- 🔒 NETWORK SECURITY (SECURE) -->
    <!-- ========================= -->

    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
    </dict>

    <!-- ========================= -->
    <!-- 📧 URL SCHEMES FOR EXTERNAL APPS -->
    <!-- ========================= -->

    <key>LSApplicationQueriesSchemes</key>
    <array>
        <string>mailto</string>
        <string>tel</string>
        <string>https</string>
        <string>http</string>
        <string>whatsapp</string>
    </array>

    <!-- ========================= -->
    <!-- 🎨 UI REQUIREMENTS -->
    <!-- ========================= -->

    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>

    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleLightContent</string>

</dict>
</plist>